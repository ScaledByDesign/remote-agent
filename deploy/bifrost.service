[Unit]
Description=Bifrost AI Gateway
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/bifrost -app-dir /opt/bifrost -port 4000 -host 0.0.0.0
Restart=always
RestartSec=5
EnvironmentFile=/opt/nanoclaw/data/env/env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bifrost

[Install]
WantedBy=multi-user.target
