# NanoClaw Agent Orchestrator — Environment Variables
# Copy to /opt/nanoclaw/.env on the droplet and fill in real values.

# LLM Provider Keys (routed through Bifrost gateway on localhost:4000)
ANTHROPIC_API_KEY=sk-bf-<your-bifrost-virtual-key>
ANTHROPIC_BASE_URL=http://localhost:4000/anthropic
OPENAI_API_KEY=sk-proj-<your-openai-key>

# Delegate Platform
DELEGATE_URL=https://delegate.ws
DELEGATE_API_KEY=<your-delegate-api-key>
NANOCLAW_TOKEN=<same-as-delegate-api-key>

# GitHub (for agent repo access)
GITHUB_TOKEN=ghp_<your-github-token>
GH_TOKEN=ghp_<your-github-token>

# Bifrost AI Gateway (health check + LLM proxy)
BIFROST_URL=http://localhost:4000
